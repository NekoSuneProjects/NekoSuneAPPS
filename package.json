{
  "name": "nekosuneapps",
  "version": "1.0.46",
  "main": "main.js",
  "bin": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "copyright": "Copyright © 2024-2026 NekoSuneVR",
    "appId": "com.nekosunevr.nekosuneapps",
    "productName": "NekoSuneAPPS",
    "appx": {
      "backgroundColor": "#0b0b14",
      "displayName": "NekoSuneAPPS",
      "publisher": "CN=NekoSuneVR",
      "publisherDisplayName": "NekoSuneVR",
      "identityName": "com.nekosunevr.nekosuneapps"
    },
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!dist/**",
      "!build-out/**",
      "!.git/**"
    ],
    "asarUnpack": [
      "node_modules/tesseract.js/**/*",
      "node_modules/tesseract.js-core/**/*",
      "node_modules/@huggingface/**/*",
      "node_modules/onnxruntime-node/**/*",
      "node_modules/onnxruntime-web/**/*",
      "node_modules/onnxruntime-common/**/*",
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*"
    ],
    "win": {
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "target": [
        "nsis",
        "msi"
      ],
      "icon": "assets/icon.ico",
      "files": [
        "main.js",
        "preload.js",
        "renderer.js",
        "index.html",
        "settings.js",
        "LICENSE",
        "README.md",
        "CHANGELOG.md",
        "assets/**/*",
        "modules/**/*",
        "package.json",
        "node_modules/**/*"
      ]
    },
    "nsis": {
      "allowToChangeInstallationDirectory": true,
      "oneClick": false
    },
    "linux": {
      "category": "AudioVideo",
      "icon": "assets/logo.png",
      "maintainer": "NekoSuneVR <nekosunevr@nekosunevr.co.uk>",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/logo.png",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "keywords": [
    "vrchat",
    "osc",
    "chatbox",
    "tiktok",
    "twitch"
  ],
  "author": {
    "name": "NekoSuneVR",
    "email": "nekosunevr@nekosunevr.co.uk"
  },
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "description": "NekoSuneAPPS - a VRChat OSC companion: chatbox, status, social suite, component stats, heart rate, TikTok & Twitch follower counters, AudioLink and Now Playing with KAT support.",
  "dependencies": {
    "@audd/sdk": "^1.5.11",
    "@aws-sdk/client-polly": "^3.1081.0",
    "@huggingface/transformers": "^4.2.0",
    "@nekosuneprojects/vrnotications": "^1.0.2",
    "acrcloud": "^1.4.0",
    "axios": "^1.7.7",
    "discord-rpc": "^4.0.1",
    "discord.js": "^14.16.3",
    "electron-store": "^8.2.0",
    "express": "^4.21.1",
    "fft-js": "^0.0.12",
    "jsqr": "^1.4.0",
    "mathjs": "^13.2.1",
    "node-fetch": "^3.3.2",
    "sql.js": "^1.12.0",
    "systeminformation": "^5.23.5",
    "tesseract.js": "^7.0.0",
    "tiktok-live-connector": "^2.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8"
  }
}
