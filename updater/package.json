{
  "name": "nekosuneapps-updater",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone update helper for NekoSuneAPPS - downloads and installs a new version while the main app is closed, then relaunches it.",
  "main": "main.js",
  "scripts": {
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.nekosunevr.nekosuneapps.updater",
    "productName": "NekoSuneAPPS Updater",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "assets/**/*",
      "!dist/**"
    ],
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico",
      "artifactName": "updater.exe"
    },
    "portable": {
      "artifactName": "updater.exe"
    },
    "mac": {
      "target": "dir",
      "icon": "assets/logo.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": "dir",
      "icon": "assets/logo.png",
      "category": "Utility"
    }
  }
}
