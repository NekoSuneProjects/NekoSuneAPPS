# Dependencies & build output
node_modules/
dist/
build-out/
out/
build/
*.log

# Standalone updater helper (updater/) - CI builds this fresh for each OS
# and normalizes the output to these paths before the main app's build
# bundles it in (see .github/workflows/build.yml); not meant to be committed.
updater/updater.exe
updater/linux-unpacked/
updater/NekoSuneAPPS Updater.app/

# Tesseract.js downloads its OCR language models into the cwd by default
*.traineddata

# OS / editor
.DS_Store
Thumbs.db
.cache/
.vs/
.idea/
.vscode/

# Secrets & local config — NEVER commit credentials/tokens/keys
.env
.env.*
*.pem
*.key
secrets.json
config.local.json
settings.local.json
**/credentials*.json
*.token
ton_re/

# Local runtime / persisted data (electron-store lives in AppData, but just in case)
config.json
user-settings.json
nekosuneosc-config.json
nekosuneapps-config.json

# Local-only helper files — do NOT publish
prompt.txt
rpc-test.js
